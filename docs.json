{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Seismic Cards API",
  "description": "Issue Visa / Mastercard virtual cards. PCI-compliant card issuing platform with sub-accounts, KYC, cardholders, budgets, real-time webhooks, and a drop-in widget for displaying full card details.",
  "colors": {
    "primary": "#0D0D0D",
    "light":   "#FAFAFA",
    "dark":    "#0D0D0D"
  },
  "appearance": {
    "default": "dark"
  },
  "background": {
    "color": {
      "light": "#FFFFFF",
      "dark":  "#0A0A0A"
    }
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark":  "/logo/dark.svg",
    "href":  "https://docs.seismic.systems"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get started",
            "pages": [
              "introduction",
              "getting-started"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "issuing-a-card",
              "pci-widget",
              "webhooks"
            ]
          },
          {
            "group": "Reference",
            "pages": [
              "api-reference",
              "errors"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "Issue your first card",
          "href":   "/issuing-a-card",
          "icon":   "credit-card"
        },
        {
          "anchor": "Webhooks",
          "href":   "/webhooks",
          "icon":   "bolt"
        },
        {
          "anchor": "PCI Widget",
          "href":   "/pci-widget",
          "icon":   "shield-check"
        }
      ]
    }
  },
  "navbar": {
    "links": [
      {
        "label": "Status",
        "href":  "https://status.seismic.systems"
      },
      {
        "label": "Support",
        "href":  "mailto:support@seismic.systems"
      }
    ],
    "primary": {
      "type":  "button",
      "label": "Talk to Sales",
      "href":  "https://www.seismic.systems"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "search": {
    "prompt": "Search the Seismic Cards docs…"
  },
  "seo": {
    "metatags": {
      "og:title":       "Seismic Cards API",
      "og:description": "Issue Visa / Mastercard virtual cards. PCI-compliant card issuing platform.",
      "og:image":       "/logo/light.svg"
    },
    "indexing": "navigable"
  },
  "footer": {
    "socials": {
      "website":  "https://www.seismic.systems",
      "x":        "https://x.com/seismicsys",
      "linkedin": "https://www.linkedin.com/company/seismicsystems"
    }
  }
}
